5. **实现数据访问对象**
   - 创建 `PassengerDAO.java`：
     ```java
     package com.airline.dao;

     import com.airline.db.DBConnection;
     import com.airline.model.Passenger;
     import java.sql.Connection;
     import java.sql.PreparedStatement;
     import java.sql.ResultSet;
     import java.sql.SQLException;
     import java.util.ArrayList;
     import java.util.List;

     public class PassengerDAO {
         public List<Passenger> getAllPassengers() throws SQLException {
             List<Passenger> passengers = new ArrayList<>();
             String sql = "SELECT * FROM passenger";
             try (Connection conn = DBConnection.getConnection();
                  PreparedStatement stmt = conn.prepareStatement(sql);
                  ResultSet rs = stmt.executeQuery()) {
                 while (rs.next()) {
                     Passenger passenger = new Passenger();
                     passenger.setId(rs.getInt("passenger_id"));
                     passenger.setName(rs.getString("passenger_name"));
                     passenger.setAge(rs.getInt("age"));
                     passenger.setGender(rs.getString("gender"));
                     passenger.setMobileNumber(rs.getString("mobile_number"));
                     passengers.add(passenger);
                 }
             }
             return passengers;
         }

         // 其他CRUD方法
     }
     ```
